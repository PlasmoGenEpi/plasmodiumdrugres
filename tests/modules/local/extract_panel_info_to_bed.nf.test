nextflow_process {

    name "Test Process EXTRACT_PANEL_INFO_TO_BED"
    script "modules/local/extract_panel_info_to_bed.nf"
    process "EXTRACT_PANEL_INFO_TO_BED"

    test("Should extract panel info without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example_PMO.json")
                input[1] = "FALSE"
                """
            }
        }

        then {
            assert process.success
            assert process.out.panel_info_bed != null
            assert path(process.out.panel_info_bed.get(0)).md5 == "126fed1aec9c298342c310095034c201"
        }

    }

    test("Should extract panel info with add_ref_seqs without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example_PMO.json")
                input[1] = "TRUE"
                """
            }
        }

        then {
            assert process.success
            assert process.out.panel_info_bed != null
            assert path(process.out.panel_info_bed.get(0)).md5 == "45dd3920fae3338cabf7aa1646fd18a0"
        }

    }

}
