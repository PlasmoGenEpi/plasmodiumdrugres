/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

params {
    modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/plasmodiumdrugres'
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners

// Use locally built images when present; only pull from a registry if missing.
// Required for unpublished module images (e.g. translate-loci) during development.
docker.pullPolicy = 'ifNotPresent'

// The main docker profile sets --platform linux/amd64 for the monolithic image.
// Locally built module images on Apple Silicon are arm64; forcing amd64 makes Docker
// ignore the local tag and try to pull from the registry (manifest unknown).
process.containerOptions = null

conda {
    channels = ['conda-forge', 'bioconda']
}
