nextflow_process {

    name "Test Process DCIFER_IBD_WRAPPER"
    script "modules/local/dcifer_ibd_wrapper.nf"
    process "DCIFER_IBD_WRAPPER"

    test("Test for failures and output file checksums with example_allele_table") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example_allele_table.tsv")
                """
            }
        }

        then {
            assert process.success
            assert process.out.btwn_host_rel != null
            assert path(process.out.btwn_host_rel.get(0)).md5 == "ab14cdddd8996f26f08ee2920373d877"
        }

    }

    test("Test for failures and output file checksums with example2_allele_table") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                """
            }
        }

        then {
            assert process.success
            assert process.out.btwn_host_rel != null
            assert path(process.out.btwn_host_rel.get(0)).md5 == "769a8a0a092f3f75a30dd709db9f1d5d"
        }

    }

}
