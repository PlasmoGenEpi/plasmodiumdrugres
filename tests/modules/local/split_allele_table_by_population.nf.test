nextflow_process {

    name "Test Process SPLIT_ALLELE_TABLE_BY_POP"
    script "modules/local/split_allele_table_by_population.nf"
    process "SPLIT_ALLELE_TABLE_BY_POP"

    test("Should run without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                input[1] = file("${projectDir}/tests/input/example2_population_map.tsv")
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.per_pop_tables.get(0)[0]).md5 == "212925ed94e11728828549a2c33f29fb"
            assert path(process.out.per_pop_tables.get(0)[1]).md5 == "80700979a24794fd6a50990609322b3d"
        }

    }

}
