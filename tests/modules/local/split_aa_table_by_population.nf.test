nextflow_process {

    name "Test Process SPLIT_AA_TABLE_BY_POP"
    script "modules/local/split_aa_table_by_population.nf"
    process "SPLIT_AA_TABLE_BY_POP"

    test("Should run without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example_amino_acid_calls.tsv.gz")
                input[1] = file("${projectDir}/tests/input/example_population_map.tsv")
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.per_pop_tables.get(0)[0]).md5 == "c7bc1fc334fa58b48703ba3b34d6273f"
            assert path(process.out.per_pop_tables.get(0)[1]).md5 == "909d88049a821d4740356a90e1210db9"
        }

    }

}
