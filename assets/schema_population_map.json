{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/plasmodiumdrugres/master/assets/schema_population_map.json",
    "title": "nf-core/plasmodiumdrugres pipeline - params.population_assignment schema",
    "description": "Schema for the file provided with params.population_assignment",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "specimen_name": {
                "anyOf": [
                    {
                        "type": "integer"
                    },
                    {
                        "type": "string",
                        "pattern": "^\\S+$"
                    }
                ],
                "errorMessage": "specimen_name must be provided and cannot contain spaces.",
                "meta": ["id"]
            },
            "population": {
                "anyOf": [
                    {
                        "type": "integer"
                    },
                    {
                        "type": "string"
                    }
                ],
                "errorMessage": "population must be provided and cannot contain spaces.",
                "meta": ["id"]
            }
        },
        "required": ["specimen_name", "population"]
    }
}
