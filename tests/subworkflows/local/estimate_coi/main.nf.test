nextflow_workflow {

    name "Test Workflow ESTIMATE_COI"
    script "subworkflows/local/estimate_coi/main.nf"
    workflow "ESTIMATE_COI"

    test("Should run without failures with int method") {

        when {
            params {
                naive_coi_threshold = 1
            }
            workflow {
                """
                input[0] = "NAIVE_INT_METHOD"
                input[1] = file("${projectDir}/tests/input/example_allele_table.tsv")
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 1
        }

    }

    test("Should run without failures with int method") {

        when {
            params {
                naive_coi_threshold = 0.5
            }
            workflow {
                """
                input[0] = "NAIVE_QUANTILE_METHOD"
                input[1] = file("${projectDir}/tests/input/example_allele_table.tsv")
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 1
        }

    }

}
