params {
    // MLAF method
    mlaf_method_options        = ["MLBM","FEM","NAIVE"]
    mlaf_method                = "MLBM"

    // SLAF method
    slaf_method_options        = ["IDM","naive"]
    slaf_method                = "IDM"

    // COI method
    coi_method_options = ["NAIVE_INT_METHOD","NAIVE_QUANTILE_METHOD"]
    coi_method = "NAIVE_INT_METHOD"
}

process {
    withName: 'MLBM_WRAPPER' {
        // Assign a closure which returns a string
        ext.args = { [
            params.mlbm_wrapper_aa_specimen_occurence_cut_off ? "--aa_sample_occurence_cut_off ${params.mlbm_wrapper_aa_specimen_occurence_cut_off}" : ""
        ].join(" ")
        }
    }

    withName: 'ESTIMATE_ML_PREVFREQ_NAIVE' {
        // Assign a closure which returns a string
        ext.args = { [
            params.naive_multilocus_wsaf_cut_off ? "--wsaf_cut_off ${params.naive_multilocus_wsaf_cut_off}" : ""
        ].join(" ")
        }
    }
    withName: 'DCIFER_SLAF_WRAPPER' {
        // Assign a closure which returns a string
        ext.args = { [
            params.dcifer_slaf_wrapper_coi_lrank ? "--coi_lrank ${params.dcifer_slaf_wrapper_coi_lrank}" : "",
            params.dcifer_slaf_wrapper_qstart ? "--qstart ${params.dcifer_slaf_wrapper_qstart}" : "",
            params.dcifer_slaf_wrapper_tol ? "--tol ${params.dcifer_slaf_wrapper_tol}" : ""

        ].join(" ")
        }
    }
}
