nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test_allele_table") {

        when {
            params {
                outdir = "$outputDir"

                allele_table               = "${projectDir}/tests/input/example2_allele_table.tsv"
                panel_info_bed             = "${projectDir}/tests/input/example_PMO_insert_locs_of_panel.bed"
                loci_of_interest_bed       = "${projectDir}/tests/input/example_principal_resistance_marker_info_table.bed"
                loci_groups                = "${projectDir}/tests/input/example2_loci_groups.tsv"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success},
                {             assert snapshot(
                    //removeNextflowVersion("$outputDir/pipeline_info/nf_core_plasmodiumdrugres_software_mqc_versions.yml"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }

    // Default test running full pipeline from a PMO input
    test("-profile test_PMO") {

        when {
            params {
                outdir = "$outputDir"

                pmo                      = "${projectDir}/tests/input/example_PMO.json"
                loci_of_interest_bed       = "${projectDir}/tests/input/example_principal_resistance_marker_info_table.bed"
                loci_groups                = "${projectDir}/tests/input/example2_loci_groups.tsv"
                // Other inputs derived within the pipeline when starting from PMO
            }
        }

        then {
            
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    stable_name,
                    stable_path
                ).match() }
            )
        }
    }
}
