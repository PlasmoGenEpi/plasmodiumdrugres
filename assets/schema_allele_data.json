{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/plasmodiumdrugres/master/assets/schema_input.json",
    "title": "nf-core/plasmodiumdrugres pipeline - params.allele_table schema",
    "description": "Schema for the file provided with params.allele_table",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "specimen_id": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Specimen ID must be provided and cannot contain spaces.",
                "meta": [
                    "id"
                ]
            },
            "target_id": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Target ID must be provided and cannot contain spaces.",
                "meta": [
                    "id"
                ]
            },
            "seq": {
                "type": "string",
                "errorMessage": "Sequence of microhaplotypes must be provided and only contain A,C,T,G.",
                "pattern": "^[ATCG]+$",
                "meta": [
                    "id"
                ]
            },
            "read_count": {
                "type": "integer",
                "errorMessage": "Read count must be an integer, but is optional.",
                "meta": [
                    "id"
                ]
            }
        },
        "required": [
            "specimen_id",
            "target_id",
            "seq"
        ]
    }
}