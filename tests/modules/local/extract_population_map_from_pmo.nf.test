nextflow_process {

    name "Test Process EXTRACT_POPULATION_MAP_FROM_PMO"
    script "modules/local/extract_population_map_from_pmo.nf"
    process "EXTRACT_POPULATION_MAP_FROM_PMO"

    test("Should run without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example_PMO.json")
                input[1] = "collection_country collection_date"
                input[2] = "_"
                """
            }
        }

        then {
            assert process.success
            assert process.out.population_map != null
            assert path(process.out.population_map.get(0)).md5 == "11366424ca554abae269ae7295cc5a3c"
        }

    }

}
