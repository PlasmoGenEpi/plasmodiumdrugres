nextflow_process {

    name "Test Process ESTIMATE_ML_PREVFREQ_NAIVE"
    script "modules/local/estimate_multilocus_prevfreq_naive.nf"
    process "ESTIMATE_ML_PREVFREQ_NAIVE"

    test("Estimating multilocus prev and frequency naively large example file, should run without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example2_amino_acid_calls.tsv")
                input[1] = file("${projectDir}/tests/input/example_loci_groups.tsv")
                """
            }
        }

        then {
            assert process.success
            assert process.out.mlaf != null
            assert process.out.slaf_from_mlaf != null

            // unpack tuple output
            def (pop, outFile_ml) = process.out.mlaf.get(0)
            def (pop_again, outFile_sl) = process.out.slaf_from_mlaf.get(0)

            assert pop == 'example2_amino_acid_calls'
            assert pop_again == 'example2_amino_acid_calls'

            // output md5 check
            assert path(outFile_ml).md5 == "08037f9f0f3fcd9e9111647611fe8c20"
            assert path(outFile_sl).md5 == "2a9e1cb57a30e6f33fb0570a0f7d4bba"

        }

    }

    test("Estimating multilocus prev and frequency naively small example file, should run without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example_amino_acid_calls.tsv")
                input[1] = file("${projectDir}/tests/input/example_loci_groups.tsv")
                """
            }
        }

        then {
            assert process.success
            assert process.out.mlaf != null
            assert process.out.slaf_from_mlaf != null

            // unpack tuple output
            def (pop, outFile_ml) = process.out.mlaf.get(0)
            def (pop_again, outFile_sl) = process.out.slaf_from_mlaf.get(0)

            assert pop == 'example_amino_acid_calls'
            assert pop_again == 'example_amino_acid_calls'

            // output md5 check
            assert path(outFile_ml).md5 == "8f9e1986a9de0de1125ca39ca556bcbc"
            assert path(outFile_sl).md5 == "e65125da916a24020bc6a392823044a9"

        }

    }

}
