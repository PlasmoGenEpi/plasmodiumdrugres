nextflow_process {

    name "Test Process ADD_REF_SEQS_WITH_TARGETED_REF_FASTA"
    script "modules/local/add_ref_seqs_with_targeted_ref_fasta.nf"
    process "ADD_REF_SEQS_WITH_TARGETED_REF_FASTA"

    test("Should run without failures") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                // define inputs of the process here. Example:
                input[0] = file("${projectDir}/tests/input/example_PMO_insert_locs_of_panel.bed")
                input[1] = file("${projectDir}/tests/input/example_PMO_insert_locs_of_panel_refseqs.fasta")
                """
            }
        }

        then {
            assert process.success
            // channel exists
            assert process.out.ref_bed_with_seqs != null
            // output md5 check
            assert path(process.out.ref_bed_with_seqs.get(0)).md5 == "5655fad30ea541867780d735327e67fe"
        }

    }

}
