nextflow_process {

    name "Test Process SPLIT_ALLELE_TABLE_BY_POP"
    script "modules/local/split_allele_table_by_population.nf"
    process "SPLIT_ALLELE_TABLE_BY_POP"

    test("Should run without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                input[1] = file("${projectDir}/tests/input/example2_population_map_indexed.tsv")
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.per_pop_tables.get(0)[0]).md5 == "a4c92fd7e08982ec463b747e310c24c2"
            assert path(process.out.per_pop_tables.get(0)[1]).md5 == "aa8a17e8149eb924ebdbf64b900fcaeb"
        }

    }

}
