nextflow_workflow {

    name "Test Workflow ESTIMATE_SLAF"
    script "subworkflows/local/estimate_slaf/main.nf"
    workflow "ESTIMATE_SLAF"

    test("Should run without failures for IDM") {

        when {
            workflow {
                """
                input[0] = "IDM"
                input[1] = channel.of(file("${projectDir}/tests/input/example_amino_acid_calls.tsv"))
                input[2] = Channel.empty()
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 1
        }

    }

    test("Should run without failures for naive method") {

        when {
            workflow {
                """
                input[0] = "naive"
                input[1] = channel.of(file("${projectDir}/tests/input/example_amino_acid_calls.tsv"))
                input[2] = Channel.empty()
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 1
        }

    }

    test("Should fail with incorrect method") {

        when {
            workflow {
                """
                input[0] = "BAD_METHOD"
                input[1] = channel.of(file("${projectDir}/tests/input/example_amino_acid_calls.tsv"))
                input[2] = Channel.empty()
                """
            }
        }
        then {
            // assert that it failed
            assert !workflow.success
        }

    }

    test("Should run without failures for mhaps_freq method") {

        when {
            params {
                population_assignment = null
            }
            workflow {
                """
                input[0] = "mhaps_freq"
                input[1] = channel.of(file("${projectDir}/tests/input/example2_allele_table.tsv"))
                input[2] = channel.of(file("${projectDir}/tests/input/example_loci_of_interest_for_target_for_microhap.tsv"))
                """
            }
        }

        then {
            assert workflow.success
        }

    }

}
