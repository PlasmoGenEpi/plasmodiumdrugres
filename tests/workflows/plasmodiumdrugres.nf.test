nextflow_workflow {

    name "Test Workflow PLASMODIUMDRUGRES"
    script "workflows/plasmodiumdrugres.nf"
    workflow "PLASMODIUMDRUGRES"

    test("Should run without failures - MLBM and naive slaf") {

        when {
            params {
                population_map = null
                population_label = "pop1"
            }
            workflow {
                """
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                input[1] = file("${projectDir}/tests/input/example_PMO_insert_locs_of_panel.bed")
                input[2] = file("${projectDir}/tests/input/example_principal_resistance_marker_info_table.bed")
                input[3] = ""
                input[4] = "MLBM"
                input[5] = file("${projectDir}/tests/input/example_loci_groups.tsv")
                input[6] = "naive"
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 6
        }

    }

    test("Should run without failures - FEM and IDM") {

        when {
            params {
                population_map = null
                population_label = "pop1"
            }
            workflow {
                """
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                input[1] = file("${projectDir}/tests/input/example_PMO_insert_locs_of_panel.bed")
                input[2] = file("${projectDir}/tests/input/example_principal_resistance_marker_info_table.bed")
                input[3] = ""
                input[4] = "FEM"
                input[5] = file("${projectDir}/tests/input/example_loci_groups.tsv")
                input[6] = "IDM"
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 6
        }

    }

    test("Should run without failures - FEM and slaf from mlaf") {

        when {
            params {
                population_map = null
                population_label = "pop1"
            }
            workflow {
                """
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                input[1] = file("${projectDir}/tests/input/example_PMO_insert_locs_of_panel.bed")
                input[2] = file("${projectDir}/tests/input/example_principal_resistance_marker_info_table.bed")
                input[3] = ""
                input[4] = "FEM"
                input[5] = file("${projectDir}/tests/input/example_loci_groups.tsv")
                input[6] = "from_mlaf"
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 6
        }

    }

    test("Should run without failures with multiple populations") {

        when {
            params {
                population_map = "${projectDir}/tests/input/example2_population_map.tsv"
            }
            workflow {
                """
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                input[1] = file("${projectDir}/tests/input/example_PMO_insert_locs_of_panel.bed")
                input[2] = file("${projectDir}/tests/input/example_principal_resistance_marker_info_table.bed")
                input[3] = ""
                input[4] = "MLBM"
                input[5] = file("${projectDir}/tests/input/example_loci_groups.tsv")
                input[6] = "naive"
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.tasks().size() == 11
        }

    }


}
