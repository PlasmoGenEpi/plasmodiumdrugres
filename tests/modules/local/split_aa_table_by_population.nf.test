nextflow_process {

    name "Test Process SPLIT_AA_TABLE_BY_POP"
    script "modules/local/split_aa_table_by_population.nf"
    process "SPLIT_AA_TABLE_BY_POP"

    test("Should run without failures") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/input/example_amino_acid_calls.tsv.gz")
                input[1] = file("${projectDir}/tests/input/example_population_map_indexed.tsv")
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.per_pop_tables.get(0)[0]).md5 == "0350eacde2df086a5cebf3e326993880"
            assert path(process.out.per_pop_tables.get(0)[1]).md5 == "cef06fa46158b9251090b2aef548e35c"
        }

    }

}
