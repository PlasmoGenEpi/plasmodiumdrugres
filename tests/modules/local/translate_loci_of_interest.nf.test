nextflow_process {

    name "Test Process TRANSLATE_LOCI_OF_INTEREST"
    script "modules/local/translate_loci_of_interest.nf"
    process "TRANSLATE_LOCI_OF_INTEREST"

    test("Should run without failures") {

        when {
            process {
                """
                // define inputs of the process here. Example:
                input[0] = file("${projectDir}/tests/input/example2_allele_table.tsv")
                input[1] = file("${projectDir}/tests/input/example_PMO_insert_locs_of_panel.bed")
                input[2] = file("${projectDir}/tests/input/example_principal_resistance_marker_info_table.bed")
                input[3] = ""
                """
            }
        }

        then {
            assert process.success
            // channel exists
            assert process.out.collapsed_amino_acid_calls != null
            // output md5 check
            assert path(process.out.collapsed_amino_acid_calls.get(0)).md5 == "9c73ed7161c4d1304a080459daceb8f1"
            assert path(process.out.amino_acid_calls.get(0)).md5 == "d3000136bf1c39dccf2a6816b3408209"
            assert path(process.out.loci_covered_by_target_samples_info.get(0)).md5 == "c732c7a2c01ef61d456ceda30ddd7e29"
            assert path(process.out.loci_of_interest_for_target_for_microhap.get(0)).md5 == "6b1079435d42c81e2fd082746a11eb51"

        }

    }

}
